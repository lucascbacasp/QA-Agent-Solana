# Wallet QA dedicada — NUNCA usar wallet principal
# Array del keypair generado con solana-keygen
QA_WALLET_PRIVATE_KEY=[1,2,3,...,64]

# RPC endpoint (Helius recomendado para mainnet)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=TU_API_KEY

# Límites de gasto (en SOL)
MAX_SPEND_PER_SESSION=0.05
MAX_SPEND_PER_TEST=0.015

# Dry run — simular sin enviar transacciones
DRY_RUN=false

# Webhook para alertas (opcional)
ALERT_WEBHOOK_URL=
